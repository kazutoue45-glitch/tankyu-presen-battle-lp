  border:3px solid var(--c-orange);
  border-radius:var(--radius-md);
  box-shadow:0 4px 24px rgba(245,166,35,.15),inset 0 0 20px rgba(255,215,0,.08);
  position:relative;
  animation:slam .65s .35s cubic-bezier(.22,1,.36,1) both;
}
.hero-theme::before{
  content:'🎯 プレゼンテーマ';
  position:absolute;top:-.7em;left:50%;transform:translateX(-50%);
  font-size:clamp(.65rem,1.8vw,.85rem);font-weight:700;
  background:linear-gradient(135deg,var(--c-orange),var(--c-red));color:#fff;
  padding:.2rem .9rem;border-radius:100px;white-space:nowrap;
  letter-spacing:.06em;
}
@keyframes slam{0%{opacity:0;transform:scale(1.3) translateY(-10px)}100%{opacity:1;transform:scale(1) translateY(0)}}

.hero-badges-wrap{
  display:flex;flex-direction:column;align-items:center;gap:.4rem;
  margin-bottom:clamp(1rem,3vw,1.5rem);
  animation:fadeUp .5s .7s both;
}
.hero-badges-row{display:flex;gap:.4rem;justify-content:center}

/* タグ — ポップイン */
.htag{
  font-family:var(--f-pop);font-size:clamp(.58rem,1.8vw,.78rem);font-weight:700;
  padding:.25rem .6rem;border-radius:100px;
  border:2px solid;
  animation:popIn .5s cubic-bezier(.22,1,.36,1) both;
  white-space:nowrap;
}
.htag--purple{border-color:var(--nordt-n);color:#fff;background:var(--nordt-n)}
.htag--green{border-color:var(--c-green);color:#fff;background:var(--c-green)}
.htag--blue{border-color:var(--c-blue);color:#fff;background:var(--c-blue)}
.htag--orange{border-color:var(--c-orange);color:#fff;background:var(--c-orange)}
@keyframes popIn{0%{opacity:0;transform:scale(.5) translateY(15px)}100%{opacity:1;transform:scale(1) translateY(0)}}

/* ─── キャラクター集合 ─── */
.hero-chars{
  display:flex;justify-content:center;align-items:flex-end;
  gap:clamp(.3rem,2vw,1.5rem);
  padding:0 1rem;
  animation:fadeUp .7s 1.1s both;
}
.hero-char{
  width:clamp(55px,10vw,110px);height:auto;
  filter:drop-shadow(0 4px 12px rgba(0,0,0,.1));
  animation:charBob 3s ease-in-out infinite;
}
.hero-char:nth-child(1){animation-delay:0s}
.hero-char:nth-child(2){animation-delay:.4s}
.hero-char:nth-child(3){animation-delay:.8s}
.hero-char:nth-child(4){animation-delay:1.2s}
.hero-char:nth-child(5){animation-delay:1.6s}
.hero-char--center{
  width:clamp(65px,12vw,130px);
  filter:drop-shadow(0 6px 20px rgba(0,0,0,.15));
}
@keyframes charBob{
  0%,100%{transform:translateY(0)}
  50%{transform:translateY(-10px)}
}

/* ─── CTA独立セクション ─── */
.cta-sec{padding:clamp(1.5rem,4vw,2.5rem) 0}
.cta-sec .cta-note{margin-top:.8rem}

/* ─── オルカ ─── */
.hero-orca{
  position:absolute;bottom:60px;right:clamp(10px,4vw,60px);
  width:clamp(80px,10vw,130px);z-index:4;
  animation:orcaBob 3.5s ease-in-out infinite;
  filter:drop-shadow(0 4px 12px rgba(0,0,0,.12));
}
@keyframes orcaBob{0%,100%{transform:translateY(0) rotate(-4deg)}50%{transform:translateY(-14px) rotate(4deg)}}

/* ─── スクロール誘導 ─── */
.hero-scroll{
  position:absolute;bottom:16px;left:50%;transform:translateX(-50%);
  z-index:5;animation:fadeUp .6s 1.5s both;
}
.hero-scroll-arrow{
  display:block;width:24px;height:24px;
  border-right:3px solid var(--c-text-muted);border-bottom:3px solid var(--c-text-muted);
  transform:rotate(45deg);opacity:.4;
  animation:scrollBounce 1.5s ease-in-out infinite;
}
@keyframes scrollBounce{
  0%,100%{transform:rotate(45deg) translateY(0);opacity:.4}
  50%{transform:rotate(45deg) translateY(8px);opacity:.7}
}

@keyframes fadeUp{0%{opacity:0;transform:translateY(22px)}100%{opacity:1;transform:translateY(0)}}

/* ─── モバイル調整 ─── */
@media(max-width:600px){
  .hero-orca{width:60px;bottom:50px;right:10px}
  .hero-bubble{opacity:.2}
  .hero-bubble--1{width:50px;height:50px}
  .hero-bubble--2{width:40px;height:40px}
  .hero-bubble--3{width:35px;height:35px}
  .hero-bubble--4{width:45px;height:45px}
  .hero-bubble--5{width:25px;height:25px}
  .hero-confetti{opacity:.3}
}


/* ─────────── SEC variants ─────────── */
.sec--white{background:#fff}
.sec--tinted{background:var(--c-bg-tinted)}


/* ─────────── S2 BENEFITS ─────────── */
.bene-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.5rem}

.bene{
  background:#fff;border-radius:var(--radius-md);padding:2.4rem 1.8rem;
  text-align:center;border:3px solid var(--c-border);position:relative;overflow:hidden;
  transition:transform .3s cubic-bezier(.22,1,.36,1),box-shadow .3s,border-color .3s;
}
.bene::after{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:var(--ac);transform:scaleX(0);transition:transform .3s;transform-origin:left}
.bene:hover{transform:translateY(-8px);box-shadow:var(--shadow-lg);border-color:var(--ac)}
.bene:hover::after{transform:scaleX(1)}

.bene-badge{width:56px;height:56px;border-radius:16px;display:inline-flex;align-items:center;justify-content:center;font-size:1.6rem;margin-bottom:1rem;color:#fff}
.bene h3{font-family:var(--f-heading);font-size:1.05rem;font-weight:900;margin-bottom:.8rem;line-height:1.55}
.bene p{font-size:.88rem;color:var(--c-text-light);line-height:1.85;text-align:left}
.bene-price{font-family:var(--f-heading);font-size:.95rem;font-weight:700;color:var(--c-red);margin-top:.8rem;text-align:center}
.bene-price s{color:var(--c-text-muted);font-weight:400}


/* ─────────── S2.5 MOVIE ─────────── */
.movie-wrap{max-width:720px;margin:0 auto 1.5rem}
.movie-placeholder{
  aspect-ratio:16/9;background:#1a1a2e;border-radius:var(--radius-md);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:.8rem;color:rgba(255,255,255,.5);cursor:pointer;
  transition:background .3s;
}
.movie-placeholder:hover{background:#2a2a3e}
.movie-play-icon{
  font-size:3rem;width:72px;height:72px;
  display:flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,.12);border-radius:50%;
  border:3px solid rgba(255,255,255,.25);
  transition:transform .3s,background .3s;
}
.movie-placeholder:hover .movie-play-icon{transform:scale(1.1);background:rgba(245,166,35,.3)}
.movie-placeholder p{font-family:var(--f-heading);font-size:.9rem;font-weight:700}
.movie-caption{
  text-align:center;font-size:.92rem;color:var(--c-text-light);
  line-height:1.85;max-width:640px;margin:0 auto;
}

/* ─────────── S2.75 THEME ─────────── */
.theme-sec{padding:clamp(2.5rem,6vw,4rem) 0}
.theme-box{
  max-width:700px;margin:0 auto;text-align:center;
  background:linear-gradient(135deg,#FFF9F0 0%,#FFF3E0 100%);
  border:3px solid var(--c-orange);
  border-radius:var(--radius-lg);
  padding:clamp(2rem,5vw,3rem) clamp(1.5rem,4vw,3rem);
  position:relative;overflow:hidden;
  box-shadow:0 8px 32px rgba(245,166,35,.15);
}
.theme-box::before{
  content:'';position:absolute;top:0;left:0;right:0;height:6px;
  background:linear-gradient(90deg,var(--c-orange),var(--c-red),var(--c-orange));
}
.theme-label{
  display:inline-block;font-family:var(--f-heading);font-size:clamp(.85rem,2vw,1rem);
  font-weight:700;color:var(--c-accent-dark);
  background:rgba(255,255,255,.7);padding:.3rem 1.2rem;border-radius:100px;
  margin-bottom:1rem;letter-spacing:.06em;
}
.theme-title{
  font-family:var(--f-heading);font-size:clamp(1.3rem,4vw,2rem);
  font-weight:900;color:var(--c-text);line-height:1.5;
  letter-spacing:.04em;
}

/* ─────────── S3 OVERVIEW + NORDT ─────────── */
.info-table{max-width:680px;margin:0 auto 3.5rem;border-radius:var(--radius-md);overflow:hidden;border:2px solid var(--c-border);background:#fff;box-shadow:var(--shadow-md)}
.info-table dl{display:contents}
.info-row{display:flex;border-bottom:1px solid var(--c-border)}
.info-row:last-child{border-bottom:none}
.info-row dt{flex:0 0 130px;padding:1rem 1.2rem;font-weight:700;font-size:.88rem;background:var(--c-bg-alt);display:flex;align-items:center}
.info-row dd{flex:1;padding:1rem 1.2rem;font-size:.92rem}
.info-free{font-family:var(--f-heading);font-weight:900;color:var(--c-red);font-size:1.2rem}

.nordt{max-width:780px;margin:0 auto}
.nordt-title{text-align:center;margin-bottom:1.5rem;display:flex;align-items:center;justify-content:center;gap:.7rem;flex-wrap:wrap}
.nordt-title span:first-child{font-family:var(--f-heading);font-size:1.2rem;font-weight:900}
.nordt-letters{font-family:var(--f-heading);font-size:2.2rem;font-weight:900;letter-spacing:.12em}
.nordt-letters b{display:inline-block}

.nordt-hero{text-align:center;margin-bottom:2.5rem;padding:2rem;background:var(--c-bg-alt);border-radius:var(--radius-md);border:2px solid var(--c-border)}
.nordt-main-copy{font-family:var(--f-heading);font-size:clamp(1.2rem,3vw,1.8rem);font-weight:900;color:var(--c-text);margin-bottom:.8rem;line-height:1.5}
.nordt-sub-copy{font-size:.92rem;color:var(--c-text-light);line-height:1.85}

.nordt-list{display:flex;flex-direction:column;gap:.9rem}
.nordt-card{
  display:flex;align-items:center;gap:1.2rem;padding:1.1rem 1.6rem;
  border-radius:var(--radius-sm);background:#fff;
  border-left:5px solid var(--nc);box-shadow:var(--shadow-sm);
  transition:transform .25s cubic-bezier(.22,1,.36,1),box-shadow .25s;
}
.nordt-card:hover{transform:translateX(8px);box-shadow:var(--shadow-md)}
.nordt-l{font-family:var(--f-heading);font-size:2.2rem;font-weight:900;color:var(--nc);width:48px;text-align:center;flex-shrink:0}
.nordt-card strong{font-family:var(--f-heading);font-size:1rem;margin-right:.4rem}
.nordt-card small{color:var(--c-text-muted);font-size:.78rem}
.nordt-card p{font-size:.88rem;color:var(--c-text-light);margin-top:.15rem}


/* ─────────── S3.5 SCHEDULE ─────────── */

/* フロー全体 */
.sched-flow{
  max-width:680px;margin:0 auto 2rem;
  display:flex;flex-direction:column;align-items:center;
}

/* カード共通 */
.sched-card{
  position:relative;overflow:hidden;
  width:100%;
  background:color-mix(in srgb,var(--pc) 8%,#fff);
  border:3px solid color-mix(in srgb,var(--pc) 30%,#fff);
  border-radius:var(--radius-lg);
  padding:clamp(1.4rem,3.5vw,2rem) clamp(1.6rem,4vw,2.2rem);
  transition:transform .35s cubic-bezier(.22,1,.36,1),box-shadow .35s,border-color .35s;
}
.sched-card:hover{
  transform:translateY(-6px) scale(1.02);
  box-shadow:0 12px 32px color-mix(in srgb,var(--pc) 25%,transparent);
  border-color:var(--pc);
}

/* ウォーターマーク番号（カード背景に大きく薄く表示） */
.sched-watermark{
  position:absolute;
  right:-8px;top:50%;transform:translateY(-50%);
  font-family:var(--f-heading);font-size:clamp(7rem,18vw,11rem);
  font-weight:900;line-height:1;
  color:color-mix(in srgb,var(--pc) 10%,transparent);
  pointer-events:none;user-select:none;
  z-index:0;
}

/* カード内コンテンツはウォーターマークの上に */
.sched-head,.sched-title,.sched-desc,.sched-teams{
  position:relative;z-index:1;
}

/* ヘッダー（ステップ番号 + 日付） */
.sched-head{
  display:flex;align-items:center;gap:.7rem;
  margin-bottom:.5rem;flex-wrap:wrap;
}
.sched-step{
  display:inline-block;
  font-family:var(--f-heading);font-size:clamp(.72rem,1.8vw,.85rem);
  font-weight:900;letter-spacing:.1em;
  color:#fff;background:var(--pc);
  padding:.28rem .85rem;border-radius:100px;
}
.sched-date{
  font-family:var(--f-heading);font-size:clamp(.8rem,2vw,.95rem);
  font-weight:700;color:var(--c-text-mid);
}

/* タイトル */
.sched-title{
  font-family:var(--f-heading);
  font-size:clamp(1.05rem,2.8vw,1.3rem);
  font-weight:900;color:var(--pc);
  margin-bottom:.4rem;
}

/* 説明文 */
.sched-desc{
  font-size:clamp(.82rem,2vw,.92rem);
  color:var(--c-text-light);line-height:1.75;
  margin-bottom:.6rem;
}

/* チーム数バッジ */
.sched-teams{
  display:inline-block;
  font-family:var(--f-pop);font-size:clamp(.75rem,1.8vw,.88rem);
  font-weight:700;color:#fff;
  background:var(--pc);
  padding:.3rem .9rem;border-radius:100px;
  box-shadow:0 2px 8px color-mix(in srgb,var(--pc) 30%,transparent);
}

/* ── カードサイズ変化（フェーズが進むほど大きく） ── */
.sched-card--1{max-width:92%}
.sched-card--2{max-width:94%}
.sched-card--3{max-width:96%}
.sched-card--4{max-width:98%}
.sched-card--5{max-width:100%}

/* 決勝カード（最大・最派手） */
.sched-card--final{
  background:linear-gradient(135deg,
    color-mix(in srgb,var(--pc) 12%,#fff) 0%,
    color-mix(in srgb,var(--pc) 6%,#fff) 50%,
    color-mix(in srgb,var(--nordt-d) 8%,#fff) 100%);
  border-width:4px;
  border-color:var(--pc);
  box-shadow:0 8px 28px color-mix(in srgb,var(--pc) 20%,transparent);
  padding:clamp(1.8rem,4.5vw,2.6rem) clamp(2rem,5vw,2.8rem);
}
.sched-card--final .sched-title{
  font-size:clamp(1.2rem,3.2vw,1.55rem);
}
.sched-card--final .sched-step{
  font-size:clamp(.82rem,2vw,.95rem);
  padding:.35rem 1rem;
}

/* ── コネクタ矢印（カード間） ── */
.sched-connector{
  display:flex;flex-direction:column;align-items:center;
  padding:.3rem 0;
}
.sched-arrow{
  width:28px;height:36px;
  filter:drop-shadow(0 2px 4px rgba(0,0,0,.1));
}
.sched-funnel{
  font-family:var(--f-pop);
  font-size:clamp(.72rem,1.8vw,.85rem);
  font-weight:700;color:var(--pc);
  margin-top:.1rem;
  text-align:center;
}

/* 注記 */
.schedule-note{
  text-align:center;font-size:.8rem;color:var(--c-text-muted);
  max-width:540px;margin:0 auto;
  padding:.6rem 1rem;background:var(--c-bg-alt);
  border-radius:var(--radius-sm);
}

/* ── モバイル調整 ── */
@media(max-width:600px){
  .sched-card--1,.sched-card--2,.sched-card--3,.sched-card--4,.sched-card--5{
    max-width:100%;
  }
  .sched-watermark{font-size:5.5rem;right:-4px}
  .sched-connector{padding:.15rem 0}
  .sched-arrow{width:22px;height:28px}
  .sched-funnel{font-size:.7rem}
}


/* ─────────── S4 DIAGNOSIS ─────────── */
.diag-intro{text-align:center;margin-bottom:2rem}
.diag-lead{font-size:1.05rem;font-weight:700;color:var(--c-text-mid);margin-bottom:.4rem}
.diag-big{font-family:var(--f-heading);font-size:clamp(1.5rem,3.5vw,2.1rem);font-weight:900;color:var(--c-orange);margin-bottom:.8rem;line-height:1.3}
.diag-desc{font-size:.92rem;line-height:1.85;color:var(--c-text-light);max-width:620px;margin:0 auto}

.diag-chars{text-align:center;margin-bottom:2.5rem}
.diag-chars-img{max-width:min(560px,90vw);margin:0 auto;border-radius:var(--radius-md);filter:drop-shadow(0 8px 24px rgba(0,0,0,.1))}

/* タイプ一覧 */
.type-showcase{display:flex;flex-direction:column;gap:2rem;margin-bottom:2rem}

/* タイプセクション見出し */
.type-section-title{
  font-family:var(--f-heading);font-size:clamp(1.1rem,2.8vw,1.4rem);font-weight:900;
  text-align:center;margin-bottom:1rem;
}

/* 横並び2列ペア */
.type-pair{display:flex;gap:1rem;max-width:600px;margin:0 auto}
.type-pair .type-card{flex:1;min-width:0}

/* ペア内カード — キャラ + テキスト縦積み（余白詰め） */
.type-card{
  border-radius:var(--radius-sm);text-align:center;
  position:relative;overflow:hidden;
  display:flex;flex-direction:column;align-items:center;
  padding:.8rem 1rem 1rem;
  transition:transform .3s cubic-bezier(.22,1,.36,1),box-shadow .3s;
}
.type-card::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:var(--tc);border-radius:4px 4px 0 0;z-index:3}
/* キャラ画像 */
.type-card-char{
  width:clamp(100px,48%,150px);height:auto;
  filter:drop-shadow(0 4px 12px rgba(0,0,0,.08));
  margin-bottom:.5rem;
}
/* テキスト情報 */
.type-card-info{text-align:center}
.type-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-md)}
.type-code{
  display:inline-block;font-family:var(--f-heading);font-size:.85rem;font-weight:900;
  color:var(--c-text-muted);background:rgba(255,249,240,.9);padding:.2rem .8rem;
  border-radius:100px;margin-bottom:.4rem;letter-spacing:.08em;
}
.type-code b{font-size:1.1rem}
.type-catch{font-size:.82rem;color:var(--c-text);line-height:1.5;margin-bottom:.25rem;font-weight:600}
.type-jobs{font-size:.72rem;color:var(--c-text-muted);line-height:1.4}

/* 独立カード（バランサー / ラスボス）— キャラ左 + テキスト右 */
.type-solo{
  border-radius:var(--radius-md);
  position:relative;overflow:hidden;
  display:flex;align-items:center;
  min-height:200px;
  max-width:600px;margin:0 auto;
  transition:transform .3s cubic-bezier(.22,1,.36,1),box-shadow .3s;
}
.type-solo::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:var(--tc);border-radius:4px 4px 0 0;z-index:3}
.type-solo:hover{transform:translateY(-6px);box-shadow:var(--shadow-lg)}
.type-solo-char{
  position:relative;flex-shrink:0;
  width:clamp(140px,18vw,200px);height:auto;
  filter:drop-shadow(0 6px 20px rgba(0,0,0,.12));
  z-index:1;padding:1rem 0 1rem 1.5rem;
}
.type-solo-content{
  position:relative;z-index:2;flex:1;text-align:center;
  padding:1.5rem 2rem;
}
.type-solo-content .type-code{font-size:1rem}
.type-solo-content .type-catch{font-size:.95rem;font-weight:700;margin-bottom:.4rem;color:var(--c-text)}
.type-solo-content .type-jobs{font-size:.8rem}

/* シークレットカード */
.secret-card{
  max-width:600px;margin:0 auto;
  background:linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%);
  border-radius:var(--radius-md);overflow:hidden;
  display:flex;align-items:center;
  position:relative;
  border:2px solid rgba(255,215,0,.3);
  box-shadow:0 0 30px rgba(255,215,0,.08),0 8px 32px rgba(0,0,0,.3);
}
/* 金色ボーダーアニメーション */
.secret-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:4px;
  background:linear-gradient(90deg,transparent,#ffd700,#ff8c00,#ffd700,transparent);
  background-size:200% 100%;
  animation:secretShimmer 3s ease-in-out infinite;
  z-index:3;
}
@keyframes secretShimmer{
  0%,100%{background-position:200% 0}
  50%{background-position:-200% 0}
}
/* シルエット領域 */
.secret-silhouette{
  position:relative;flex-shrink:0;
  width:clamp(130px,18vw,180px);
  padding:1.2rem 0 1.2rem 1.2rem;
}
.secret-char{
  width:100%;height:auto;
  filter:brightness(0) drop-shadow(0 0 20px rgba(255,215,0,.3));
  opacity:.7;
  transition:filter .4s,opacity .4s;
}
.secret-card:hover .secret-char{
  filter:brightness(0) drop-shadow(0 0 30px rgba(255,215,0,.6));
  opacity:.9;
}
/* キャラの上のオーバーレイ（？マーク） */
.secret-overlay{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  font-size:clamp(3rem,8vw,4.5rem);font-weight:900;
  color:rgba(255,215,0,.5);
  text-shadow:0 0 20px rgba(255,215,0,.3);
  pointer-events:none;
  animation:secretPulse 2s ease-in-out infinite;
}
.secret-overlay::after{content:'?'}
@keyframes secretPulse{
